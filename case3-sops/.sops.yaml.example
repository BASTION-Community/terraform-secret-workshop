# ── SOPS 설정 템플릿 ───────────────────────────────────────
# .sops.yaml은 sops가 자동 생성하지 않는다.
# case3-sops/ 루트에 .sops.yaml로 복사한 뒤 kms 값을 실제 ARN으로 교체한다.
#
# 사용법:
#   1. terraform apply (kms.tf) → KMS ARN 획득
#   2. cp .sops.yaml.example .sops.yaml
#   3. .sops.yaml의 kms 필드에 실제 ARN 입력
#   4. sops --encrypt --in-place secrets/demo.yaml

creation_rules:
  - path_regex: secrets/.*\.yaml$
    kms: "arn:aws:kms:ap-northeast-2:ACCOUNT_ID:key/KEY_ID"
