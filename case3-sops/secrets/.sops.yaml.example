# ── SOPS 설정 템플릿 ───────────────────────────────────────
# .sops.yaml은 sops가 자동 생성하지 않는다.
# secrets/ 디렉터리 안에 .sops.yaml로 복사한 뒤 kms 값을 실제 ARN으로 교체한다.
#
# 사용법:
#   1. terraform apply (kms.tf) → KMS ARN 획득
#   2. cd secrets
#   3. cp .sops.yaml.example .sops.yaml
#   4. .sops.yaml의 kms 필드에 실제 ARN 입력
#   5. sops --encrypt --in-place demo.yaml
#
# 참고:
# path_regex는 .sops.yaml 위치를 기준으로 매칭된다.
# 이 파일이 secrets/ 안에 있으므로 demo.yaml은 상대경로상 그냥 demo.yaml이다.

creation_rules:
  - path_regex: .*\.yaml$
    kms: "arn:aws:kms:ap-northeast-2:ACCOUNT_ID:key/KEY_ID"
