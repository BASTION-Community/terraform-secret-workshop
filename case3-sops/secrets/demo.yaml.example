# ── SOPS 암호화 전 평문 예시 ────────────────────────────────
# 이 파일은 SOPS 암호화 전의 원본 구조를 보여주기 위한 예시이다
# 실제로는 sops --encrypt 후 암호화된 demo.yaml을 사용한다
#
# 사용법:
#   1. 이 파일을 demo.yaml로 복사
#   2. 실제 값으로 수정
#   3. sops --encrypt --in-place demo.yaml
#
# 결과: demo.yaml의 각 값이 ENC[AES256_GCM,data:...,type:str] 형태로 암호화됨

"/demo/api-key-1": "test-a1b2c3"
"/demo/api-key-2": "test-d4e5f6"
"/demo/api-key-3": "test-g7h8i9"
